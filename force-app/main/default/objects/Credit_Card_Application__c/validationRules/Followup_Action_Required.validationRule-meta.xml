<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Followup_Action_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Follow_up_Requested_On__c)),
  Follow_up_Requested_On__c &lt;= NOW(),
  ISBLANK(Follow_up_Action__c)
)</errorConditionFormula>
    <errorDisplayField>Follow_up_Action__c</errorDisplayField>
    <errorMessage>Please describe the Follow-up Action when a Follow-up Date is set.</errorMessage>
</ValidationRule>
