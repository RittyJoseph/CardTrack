<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rejection_Reason_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL( Application_Status__c , &quot;Rejected&quot;),
  ISBLANK(TEXT( Rejection_Reason__c ))
)</errorConditionFormula>
    <errorDisplayField>Rejection_Reason__c</errorDisplayField>
    <errorMessage>Please select a Rejection Reason when marking an application as Rejected.</errorMessage>
</ValidationRule>
