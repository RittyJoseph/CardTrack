<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Minimum_Salary_Requirement</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Monthly_Salary__c)),
  Monthly_Salary__c&lt; 5000
)</errorConditionFormula>
    <errorDisplayField>Monthly_Salary__c</errorDisplayField>
    <errorMessage>Monthly salary must be at least AED 5,000 to qualify for a credit card.</errorMessage>
</ValidationRule>
