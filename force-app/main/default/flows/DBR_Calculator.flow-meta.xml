<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <customProperties>
        <name>ScreenProgressIndicator</name>
        <value>
            <stringValue>{&quot;location&quot;:&quot;top&quot;,&quot;type&quot;:&quot;simple&quot;}</stringValue>
        </value>
    </customProperties>
    <environments>Default</environments>
    <formulas>
        <name>f_Calculate_DBR</name>
        <dataType>Number</dataType>
        <expression>(({!Total_Monthly_Payments} + ({!Total_Credit_Card_Limit} * 0.05)) / {!Monthly_Income}) * 100</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>DBR Calculator {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DBR Calculator</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <screens>
        <name>DBR_Calculator</name>
        <label>DBR Calculator</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>true</allowPause>
        <connector>
            <targetReference>Results_Text</targetReference>
        </connector>
        <fields>
            <name>Total_Credit_Card_Limit</name>
            <dataType>Number</dataType>
            <fieldText>Total Credit Card Limit</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <scale>0</scale>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Total_Monthly_Payments</name>
            <dataType>Number</dataType>
            <fieldText>Total Monthly Payments (Loan / EMIs)</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>false</isRequired>
            <scale>0</scale>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Monthly_Income</name>
            <dataType>Number</dataType>
            <fieldText>Monthly Income</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <scale>0</scale>
            <styleProperties>
                <styleSettings>
                    <propertyName>--slds-c-input-color-background</propertyName>
                    <propertyValue>
                        <stringValue>#FFFFFF</stringValue>
                    </propertyValue>
                </styleSettings>
                <styleSettings>
                    <propertyName>--slds-c-input-text-color</propertyName>
                    <propertyValue>
                        <stringValue>#050505</stringValue>
                    </propertyValue>
                </styleSettings>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>Results_Text</name>
        <label>DBR Results</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>true</allowPause>
        <fields>
            <name>Final_DBR_Output</name>
            <fieldText>&lt;p&gt;&lt;strong&gt;Calculation Complete!&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Your calculated Debt Burden Ratio (DBR) is: &lt;code&gt;&lt;strong&gt;{!f_Calculate_DBR}%&lt;/strong&gt;&lt;/code&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>DBR_Calculator</targetReference>
        </connector>
    </start>
    <status>Active</status>
</Flow>
